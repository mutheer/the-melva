# Example environment variables for local development.
# Copy this file to .env (which is git-ignored) and fill in real values.
#
# In production these MUST be set in:
#   Netlify dashboard → Site → Site configuration → Environment variables

# From @BotFather in Telegram
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID (or a group's chat ID — negative number)
TELEGRAM_CHAT_ID=

# Optional: lock the function to one origin in production.
# Leave unset (or "*") to allow Netlify preview deploys to call it.
# ALLOWED_ORIGIN=https://www.themelva.com
